{
  "entities": {
    "Checklist": {
      "title": "Checklist",
      "description": "Comprehensive lease lifecycle management data for a specific customer.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string", "description": "Name of the customer" },
        "phasesData": { "type": "string", "description": "JSON stringified lifecycle phases and tasks" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "createdBy": { "type": "string", "description": "UID of the creator" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "phasesData", "status", "createdBy", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/checklists/{checklistId}": {
      "schema": "Checklist",
      "description": "Collection containing all customer lease checklists."
    }
  }
}
